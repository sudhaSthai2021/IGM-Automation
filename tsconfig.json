{
  "compilerOptions": {
  "target": "ES2020",
  "module": "commonjs",
  "lib": ["ES2020", "DOM"],
  "types": ["node", "@playwright/test"],
  "moduleResolution": "node",
  "resolveJsonModule": true,
  "strict": false,
  "esModuleInterop": true,
  "skipLibCheck": true,
  "outDir": "dist"
},
  "include": [
    "features/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts",
    "test-data/**/*.ts",
    "utils/**/*.ts"
  ]
}